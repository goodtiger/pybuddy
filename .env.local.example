# AI小老师配置

# === 必须配置 ===
# 在 https://platform.openai.com/api-keys 获取
OPENAI_API_KEY=

# === 可选：自定义模型提供商 ===

# 基础 URL（支持任何 OpenAI 兼容接口）
# OpenAI 官方：https://api.openai.com/v1
# 硅基流动：https://api.siliconflow.cn/v1
# DeepSeek：https://api.deepseek.com/v1
# Groq：https://api.groq.com/openai/v1
# 智谱：https://open.bigmodel.cn/api/paas/v4
AI_BASE_URL=https://api.openai.com/v1

# API 端点格式
# responses = OpenAI Responses API（仅 OpenAI 官方支持）
# chat = OpenAI Chat Completions API（所有提供商都支持）
# 不填时：OpenAI 官方 URL 默认用 responses，其他用 chat
# AI_API_ENDPOINT=chat

# 模型名称
# OpenAI: gpt-4.1-mini, gpt-4o-mini, gpt-4o
# 硅基流动: Qwen/Qwen2.5-72B-Instruct, deepseek-ai/DeepSeek-V3
# DeepSeek: deepseek-chat
# Groq: llama-3.3-70b-versatile, mixtral-8x7b-32768
OPENAI_TUTOR_MODEL=gpt-4.1-mini
